# MV Consulting ERP — API Protection
# Solo router.php è accessibile direttamente

# Abilita il passaggio dell'header Authorization per FastCGI/PHP-FPM
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

RewriteEngine On

# Forza l'header Authorization a passare alle variabili d'ambiente di PHP
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

# Se il file richiesto è router.php, health.php o migrate.php, lascialo passare
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^router\.php$ - [L]
RewriteRule ^health\.php$ - [L]
RewriteRule ^migrate\.php$ - [L]
RewriteRule ^reset2\.php$ - [L]

# Blocca accesso diretto a tutti gli altri file PHP
<FilesMatch "^(?!router\.php$|health\.php$|migrate\.php$|reset2\.php$).*\.php$">
    Require all denied
</FilesMatch>

# Blocca accesso alla directory Shared e Controllers
<IfModule mod_rewrite.c>
    RewriteRule ^(Controllers|Shared)/ - [F,L]
</IfModule>

# Blocca accesso a file di migrazione e setup
<FilesMatch "\.(sql|log|bak|env|example)$">
    Require all denied
</FilesMatch>
