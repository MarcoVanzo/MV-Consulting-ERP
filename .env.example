# Production Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Connection
DB_HOST=your_db_host
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password
DB_PREFIX=mv_
DB_TYPE=mysql

# Application Configuration
APP_NAME="MV Consulting ERP"
APP_ENV=production
APP_DEBUG=false

# Security — IMPORTANT: Use a strong, unique secret (min 32 chars)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRATION=86400

# File Paths
UPLOAD_DIR=../uploads/
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,csv,doc,docx
MAX_UPLOAD_SIZE=10485760

# OpenAPI.it — Verifica P.IVA
OPENAPI_IT_TOKEN=your_openapi_token

# Google Calendar OAuth (per Trasferte)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://www.mv-consulting.it/ERP/api/router.php?module=google&action=callback
GOOGLE_CALENDAR_IDS=calendar_id_1,calendar_id_2
