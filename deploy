#!/bin/bash

echo "======================================"
echo "   MV Consulting ERP - Deploy Tool    "
echo "======================================"
echo ""

# 1. ADD ALL FILES TO GIT
echo "📦 1/3 - Verifica modifiche locali..."
git add .

# Check if there are changes to commit
if git diff --cached --quiet; then
    echo "Nessuna modifica da salvare su GitHub."
else
    # 2. PROMPT FOR COMMIT MESSAGE (or auto-generate)
    echo "Trovate modifiche locali pronte per il salvataggio."
    read -p "Inserisci un messaggio per il commit (oppure premi INVIO per un messaggio automatico): " msg
    
    if [ -z "$msg" ]; then
        msg="Auto-deploy: $(date +'%Y-%m-%d %H:%M:%S')"
    fi
    
    git commit -m "$msg"
    
    # 3. PUSH TO GITHUB
    echo "🌍 2/3 - Invio codice su GitHub..."
    git push origin main || echo "⚠️ Git push limitato/fallito (magari manca auth). Procedo col deploy FTP..."
fi

# 4. RUN FTP UPLOAD (--no-git perché git è già gestito sopra)
echo "🚀 3/3 - Caricamento su Aruba (FTP)..."
if command -v python3 &>/dev/null; then
    python3 deploy.py --no-git "$@"
else
    python deploy.py --no-git "$@"
fi

echo ""
echo "✨ Finito! Il sistema ha gestito tutto."
echo "======================================"
