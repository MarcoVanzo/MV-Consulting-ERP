#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# MV Consulting ERP — Deploy Configuration
# Questo file viene letto da deploy.sh e deploy.py
# ═══════════════════════════════════════════════════════════════

# ── Identity ──
PROJECT_NAME="MV Consulting ERP"
GITHUB_REPO="MarcoVanzo/MV-Consulting-ERP"
DEPLOY_BRANCH="main"

# ── URLs ──
DEPLOY_URL="https://www.mv-consulting.it/ERP/deploy_update.php"
APP_URL="https://www.mv-consulting.it/ERP"
HEALTH_URL="https://www.mv-consulting.it/ERP/api/health.php"
PING_URL=""
MIGRATE_URL="https://www.mv-consulting.it/ERP/api/migrate.php"

# ── Credentials ──
ENV_FILE=".env.deploy"

# ── Features ──
HAS_REACT_APPS=false
REACT_APPS=""
HAS_SERVICE_WORKER=false
HAS_PHPSTAN=false
HAS_STRESS_TEST=false

# ── FTP Fallback ──
FTP_HOST_VAR="FTP_SERVER"
FTP_USER_VAR="FTP_USERNAME"
FTP_PASS_VAR="FTP_PASSWORD"
FTP_DIR_VAR="FTP_PATH"
FTP_MAX_WORKERS=4
